{
  "name": "guifier-react",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome lint --diagnostic-level=error src/",
    "lint:fix": "biome lint --write --unsafe src/",
    "format": "biome format --write src/",
    "format:check": "biome format --diagnostic-level=error src/",
    "check": "biome check --write src/",
    "type-check": "tsc --noEmit",
    "check-all": "biome check --write src/ && tsc --noEmit",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.0",
    "@codemirror/view": "^6.38.0",
    "@decimalturn/toml-patch": "^0.5.2",
    "@uiw/codemirror-extensions-langs": "^4.25.0",
    "@uiw/react-codemirror": "^4.25.0",
    "antd": "^5.24.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "fast-xml-parser": "^5.3.2",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.21",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.4.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx biome check --staged --write --no-errors-on-unmatched",
    "commit-msg": "bun -e \"const msg=require('fs').readFileSync(process.argv[1],'utf8').trim();const p=/^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\\(.+\\))?: .+/;if(!p.test(msg)){console.error('ERROR:Commit message must match format: type(scope): description');process.exit(1)}\""
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.20",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.0",
    "vite": "^8.0.13"
  }
}
